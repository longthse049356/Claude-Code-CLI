{
  "name": "clawd-rebuild",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --parallel dev:server dev:ui",
    "dev:server": "bun run src/server.ts",
    "dev:ui": "cd packages/ui && bun run dev",
    "build:ui": "cd packages/ui && bun run build",
    "start": "bun run src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
