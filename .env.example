# Copy file này thành .env và điền API key của bạn
# cp .env.example .env

# --- Anthropic official API ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- ChiaSeGPU proxy (tiết kiệm chi phí) ---
# ANTHROPIC_API_KEY=your-chiasegpu-key
# ANTHROPIC_BASE_URL=https://llm.chiasegpu.vn/v1
# ANTHROPIC_MODEL=Sonnet4.6
